<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>PrimeDigitals — Premium Digital Subscriptions & Growth</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
<style>
:root{
  --gold:#C9A84C;--gl:#E2C06A;--gd:#9A7835;
  --bg:#09090F;--bg2:#111118;--bg3:#18181F;
  --border:rgba(201,168,76,.14);--borderh:rgba(201,168,76,.38);
  --text:#F0EDE6;--muted:#8A8A9A;
  --serif:'Cormorant Garamond',serif;--sans:'DM Sans',sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:var(--sans);overflow-x:hidden;}
nav{position:fixed;top:0;left:0;right:0;z-index:200;height:66px;padding:0 5%;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border);background:rgba(9,9,15,.9);backdrop-filter:blur(14px);}
.logo{font-family:var(--serif);font-size:22px;font-weight:700;color:var(--text);text-decoration:none;}
.logo span{color:var(--gold);}
.nav-links{display:flex;gap:28px;}
.nav-links a{color:var(--muted);text-decoration:none;font-size:13.5px;font-weight:500;transition:color .2s;}
.nav-links a:hover{color:var(--text);}
.nav-cta{padding:8px 22px;background:var(--gold);color:#09090F;border:none;border-radius:4px;font-family:var(--sans);font-size:13px;font-weight:700;cursor:pointer;text-decoration:none;transition:background .2s;}
.nav-cta:hover{background:var(--gl);}
#hero{min-height:100vh;display:flex;align-items:center;padding:110px 5% 70px;position:relative;overflow:hidden;}
.hgrid{position:absolute;inset:0;background-image:linear-gradient(rgba(201,168,76,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(201,168,76,.025) 1px,transparent 1px);background-size:55px 55px;}
.hcontent{position:relative;max-width:680px;}
.htitle{font-family:var(--serif);font-size:clamp(52px,8vw,88px);font-weight:700;line-height:1.03;margin-bottom:22px;letter-spacing:-1.5px;}
.htitle .g{background:linear-gradient(135deg,var(--gold),var(--gl));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.hsub{font-size:15.5px;color:var(--muted);max-width:460px;line-height:1.75;margin-bottom:40px;font-weight:300;}
.btnp{padding:14px 32px;background:var(--gold);color:#09090F;border:none;border-radius:4px;font-family:var(--sans);font-size:14px;font-weight:700;cursor:pointer;text-decoration:none;display:inline-block;transition:all .2s;}
.sec{padding:88px 5%;}
.stag{font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:13px;}
.stitle{font-family:var(--serif);font-size:clamp(34px,5vw,50px);font-weight:700;margin-bottom:13px;}
.fbar{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:44px;}
.flt{padding:8px 20px;border:1px solid var(--border);border-radius:3px;background:transparent;color:var(--muted);font-family:var(--sans);font-size:13px;cursor:pointer;transition:all .2s;}
.flt.on,.flt:hover{border-color:var(--gold);color:var(--gold);background:rgba(201,168,76,.06);}
.pgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(282px,1fr));gap:20px;}
.pcard{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:26px;transition:all .3s;position:relative;overflow:hidden;cursor:pointer;}
.cbadge{position:absolute;top:14px;right:14px;padding:3px 10px;font-size:10px;font-weight:700;border-radius:2px;}
.cicon{width:50px;height:50px;background:var(--bg3);border:1px solid var(--border);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:24px;margin-bottom:18px;}
.cname{font-family:var(--serif);font-size:21px;font-weight:700;margin-bottom:9px;}
.cdesc{font-size:13px;color:var(--muted);line-height:1.6;margin-bottom:18px;}
.cprice{font-family:var(--serif);font-size:26px;font-weight:700;}
.cprice span{font-size:13px;font-weight:400;color:var(--muted);}
.bbtn{padding:9px 20px;border:none;border-radius:3px;font-weight:700;cursor:pointer;}
.ov{position:fixed;inset:0;background:rgba(0,0,0,.78);backdrop-filter:blur(8px);z-index:500;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .25s;}
.ov.open{opacity:1;pointer-events:all;}
.mo{background:var(--bg2);padding:36px;width:100%;max-width:500px;border-radius:12px;}
.moinput{width:100%;padding:11px 14px;background:var(--bg3);border:1px solid var(--border);color:var(--text);margin-bottom:14px;}
footer{background:var(--bg2);border-top:1px solid var(--border);padding:56px 5% 26px;}
.toast{position:fixed;bottom:22px;left:50%;transform:translateX(-50%) translateY(70px);background:var(--bg2);padding:12px 22px;border-radius:6px;z-index:9999;transition:transform .3s;}
.toast.show{transform:translateX(-50%) translateY(0);}
</style>
</head>
<body>

<nav>
  <a href="#" class="logo">Prime<span>Digitals</span></a>
  <div class="nav-links">
    <a href="#products">Subscriptions</a>
    <a href="#how">How It Works</a>
  </div>
  <a href="#products" class="nav-cta">Shop Now</a>
</nav>

<section id="hero">
  <div class="hgrid"></div>
  <div class="hcontent">
    <div class="htag">Premium Digital Marketplace</div>
    <h1 class="htitle">Your <span class="g">Digital</span><br/>Empire Starts<br/>Here.</h1>
    <p class="hsub">Premium software subscriptions, social media growth, and cutting-edge AI tools — delivered instantly.</p>
    <a href="#products" class="btnp">Browse Products</a>
  </div>
</section>

<section class="sec" id="products">
  <div class="stag">Full Catalog</div>
  <h2 class="stitle">All Products & Services</h2>
  <div class="fbar" id="fbar"></div>
  <div class="pgrid" id="pgrid"></div>
</section>

<footer>
  <div class="fbot"><p>© 2025 PrimeDigitals. All rights reserved.</p><a href="admin.html" style="color:var(--gold);text-decoration:none;font-size:12px">Admin</a></div>
</footer>

<div class="ov" id="buyModal">
  <div class="mo">
    <h2 id="moName" class="cname"></h2>
    <p id="moPrice" class="cdesc"></p>
    <input type="email" id="fInvoice" class="moinput" placeholder="Your Email Address"/>
    <div id="ppcont"></div>
    <button onclick="closeBuy()" class="flt" style="width:100%;margin-top:10px">Cancel</button>
  </div>
</div>

<div class="toast" id="toast"></div>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
import { getFirestore, collection, onSnapshot } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

const firebaseConfig = {
  apiKey: "AIzaSyCGm3VNJSnCqJ4kgl6qHY7BBCBYFjPhcwU",
  authDomain: "primedigitals-1802f.firebaseapp.com",
  projectId: "primedigitals-1802f",
  storageBucket: "primedigitals-1802f.firebasestorage.app",
  messagingSenderId: "199046655270",
  appId: "1:199046655270:web:07f214e11244f615d625c7",
  measurementId: "G-8H15L7X9QL"
};

const app = initializeApp(firebaseConfig);
const db = getFirestore(app);

let allProducts = [];

function renderGrid(list) {
  document.getElementById('pgrid').innerHTML = list.map(p => `
    <div class="pcard" onclick="openBuy('${p.id}')">
      <div class="cicon">${p.icon || '📦'}</div>
      <div class="cname">${p.name}</div>
      <div class="cdesc">${p.desc || ''}</div>
      <div class="cfoot">
        <div class="cprice">$${p.price}<span> / ${p.period}</span></div>
        <button class="btnp" style="padding:8px 15px; font-size:12px">Buy</button>
      </div>
    </div>
  `).join('');
}

function renderFilters() {
  const cats = ['All', ...new Set(allProducts.map(p => p.cat))];
  document.getElementById('fbar').innerHTML = cats.map(c => `
    <button class="flt" onclick="filterProds('${c}')">${c}</button>
  `).join('');
}

window.filterProds = (cat) => {
  const filtered = cat === 'All' ? allProducts : allProducts.filter(p => p.cat === cat);
  renderGrid(filtered);
};

onSnapshot(collection(db, "products"), (snapshot) => {
  allProducts = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
  renderGrid(allProducts);
  renderFilters();
});

window.openBuy = (id) => {
  const sel = allProducts.find(p => p.id === id);
  document.getElementById('moName').innerText = sel.name;
  document.getElementById('moPrice').innerText = `$${sel.price}`;
  document.getElementById('buyModal').classList.add('open');
};

window.closeBuy = () => document.getElementById('buyModal').classList.remove('open');

</script>
</body>
</html>
